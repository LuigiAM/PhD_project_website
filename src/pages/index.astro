.demo-card { background-color: var(--color-white); border-radius: 12px; border: 1px solid var(--color-border); overflow: hidden; display: flex; flex-direction: column; box-shadow: 0 4px 15px rgba(0,0,0,0.05); }
.demo-card .media-container { background-color: #000; line-height: 0; }
.demo-card .media-container img { width: 100%; height: auto; aspect-ratio: 16/9; object-fit: cover; display: block; }
.demo-card .text-content { padding: 1.5rem; text-align: left; }
.demo-card .text-content h3 { font-size: 1.5rem; margin-bottom: 0.5rem; }
.demo-card .text-content p { color: var(--color-text-muted); line-height: 1.6; }

