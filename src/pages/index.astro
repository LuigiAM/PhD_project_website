/* DEMO */
.demo-wrapper { padding-top: 2rem; padding-bottom: 2rem; text-align: center; }
.demo-header h2 { font-size: 2.5rem; margin-bottom: 0.5rem; }
.demo-header p { font-size: 1.125rem; color: var(--color-text-muted); margin-bottom: 2.5rem; max-width: 600px; margin-left: auto; margin-right: auto; }
.demo-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; text-align: left; }
