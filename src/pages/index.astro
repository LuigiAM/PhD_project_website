.hero-video iframe { width: 100%; height: min(60vh, 720px); max-height: 720px; border: 0; box-shadow: none; display: block; }
@media (max-width: 900px) {
  .hero-video { max-width: 100%; }
  .hero-video iframe { height: 40vh; }
}
</style>